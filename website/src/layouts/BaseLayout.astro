---
import "../styles/global.css";
const { title = "Georgia Trout" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="River intelligence, current trout conditions, reports, stocking updates, and fly recommendations for Georgia trout water."
    />
  </head>

  <body>
    <slot />
  </body>
</html>
