---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import RiverCard from "../components/RiverCard.astro";
import LatestReport from "../components/LatestReport.astro";
import LatestVideo from "../components/LatestVideo.astro";
import FlyOfWeek from "../components/FlyOfWeek.astro";
import Footer from "../components/Footer.astro";

import homepage from "../../../site_data/homepage.json";

const rivers = homepage.rivers || [];
---

<BaseLayout title="Georgia Trout">
  <Header />

  <Hero />

  <main>

    <section class="home-section" id="rivers">

      <div class="section-header">
        <h2 class="section-title">Current Rivers</h2>

        <a class="text-link" href="/rivers">
          View All Rivers →
        </a>
      </div>

      <div class="river-grid">
        {rivers.map((river) => (
          <RiverCard river={river} />
        ))}
      </div>

    </section>

    <section class="feature-grid">

      <LatestReport />

      <LatestVideo />

      <FlyOfWeek />

    </section>

  </main>

  <Footer />
</BaseLayout>
